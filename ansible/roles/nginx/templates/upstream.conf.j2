# {{ ansible_managed }}
#
# Weighted upstream + reverse-proxy server block.
# Parameters: weight_canary, weight_stable (must sum to 100).
# Hosts: app-vm1, app-vm2 (from /etc/hosts seeded by Ansible).

upstream gitops_api {
    server app-vm1:8080 weight={{ weight_canary }};
    server app-vm2:8080 weight={{ weight_stable }};
}

server {
    listen 80 default_server;
    server_name _;

    location / {
        proxy_pass http://gitops_api;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
