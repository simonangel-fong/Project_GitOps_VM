# {{ ansible_managed }}
# Weighted upstream + reverse-proxy server block.
# Parameter: weight_canary (0..100). weight_stable is derived as (100-wc).
# nginx detail: weight=0 is invalid; we use `down` for fully-excluded backends.
{% set wc = weight_canary | int %}
{% set ws = 100 - wc %}

upstream gitops_api {
{% if wc == 0 %}
    server app-vm1:8080 down;
    server app-vm2:8080 weight={{ ws }};
{% elif ws == 0 %}
    server app-vm1:8080 weight={{ wc }};
    server app-vm2:8080 down;
{% else %}
    server app-vm1:8080 weight={{ wc }};
    server app-vm2:8080 weight={{ ws }};
{% endif %}
}

server {
    listen 80 default_server;
    server_name _;

    location / {
        proxy_pass http://gitops_api;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
